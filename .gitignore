# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   checked in the project's metadata. In a case like this, you can comment these lines.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files are meant to be committed.
#   However, in some cases (e.g. libraries), you may want to ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally committed, but can be ignored in libraries.
# poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally committed, but can be ignored in libraries.
# .pdm-python

# PEP 582; used by e.g. github.com/pypa/pipenv
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

